{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "roundhouse-v2-model-broker",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "workers_dev": false,
  "preview_urls": false,
  "ai": { "binding": "AI", "remote": true },
  "vars": {
    "AI_GATEWAY_ID": "roundhouse-v2-development",
    "ROUTING_MODEL": "openai/gpt-5.6-sol",
    "ROUTING_ROUTES": "{\"plan\":{\"provider\":\"anthropic\",\"model\":\"anthropic/claude-opus-4.8\",\"protocol\":\"anthropic-messages\"},\"implement\":{\"provider\":\"openai\",\"model\":\"openai/gpt-5.6-sol\",\"protocol\":\"openai-responses\"},\"review-holistic\":{\"provider\":\"anthropic\",\"model\":\"anthropic/claude-fable-5\",\"protocol\":\"anthropic-messages\"},\"review-security\":{\"provider\":\"moonshotai\",\"model\":\"moonshotai/kimi-k3\",\"protocol\":\"openai-completions\"},\"review-data\":{\"provider\":\"moonshotai\",\"model\":\"moonshotai/kimi-k3\",\"protocol\":\"openai-completions\"}}",
    "ROUTING_REASONING_EFFORT": "low",
  },
  "observability": { "enabled": true },
}
