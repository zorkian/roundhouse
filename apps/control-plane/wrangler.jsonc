{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "roundhouse-v2-control-plane",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "workers_dev": true,
  "preview_urls": false,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "roundhouse-v2-development",
      "database_id": "8d3dfa61-e922-4c7b-ae26-199319eba0b5",
      "migrations_dir": "migrations",
    },
  ],
  "queues": {
    "producers": [
      {
        "binding": "RUN_WAKEUPS",
        "queue": "roundhouse-v2-development-wakeups",
      },
    ],
    "consumers": [
      {
        "queue": "roundhouse-v2-development-wakeups",
        "dead_letter_queue": "roundhouse-v2-development-wakeups-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 5,
      },
    ],
  },
  "artifacts": [
    { "binding": "ARTIFACTS", "namespace": "roundhouse-v2-development" },
  ],
  "services": [
    {
      "binding": "MODEL_BROKER",
      "service": "roundhouse-v2-model-broker",
    },
  ],
  "containers": [
    {
      "class_name": "RoundhouseAttemptContainer",
      "image": "../../containers/agent-runner/Dockerfile",
      "instance_type": "lite",
      "max_instances": 10,
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "ATTEMPT_CONTAINERS",
        "class_name": "RoundhouseAttemptContainer",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v2-phase-1",
      "new_sqlite_classes": ["RoundhouseAttemptContainer"],
    },
  ],
  "triggers": { "crons": ["*/5 * * * *"] },
  "vars": {
    "ARTIFACTS_NAMESPACE": "roundhouse-v2-development",
    "ARTIFACTS_REMOTE_ORIGIN": "https://07ff5b32b60ae3e5d613b90ddde90069.artifacts.cloudflare.net",
    "CONTROL_PLANE_ORIGIN": "https://roundhouse-v2-control-plane.default-07f.workers.dev",
    "GITHUB_APP_ID": "4281837",
    "GITHUB_APP_INSTALLATION_ID": "146147681",
  },
  "observability": {
    "enabled": true,
  },
}
