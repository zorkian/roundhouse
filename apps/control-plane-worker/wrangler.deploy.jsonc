{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "roundhouse-dev-control-plane",
  "main": "src/deploy.ts",
  "compatibility_date": "2026-07-11",
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "invocation_logs": true,
      "persist": true,
    },
  },
  "triggers": {
    "crons": ["*/5 * * * *"],
  },
  "vars": {
    "ROUNDHOUSE_ENVIRONMENT": "development",
    "ROUNDHOUSE_PUBLIC_ORIGIN": "https://roundhouse-dev.rm-rf.rip",
    "ROUNDHOUSE_REPOSITORY": "zorkian/roundhouse",
    "ROUNDHOUSE_WORKER_ID": "roundhouse-dev-control-plane",
    "AUTH_MODE": "access",
    "ACCESS_TEAM_DOMAIN": "zorkian",
    "ACCESS_POLICY_AUD": "93175877f79ccfad4f2d7b0ed35f9df6ec1901269474150486076320a74f141a",
    "DELEGATED_ACTOR_ID": "zorkian@fastmail.fm",
    "EXECUTION_MODE": "cloudflare-trusted-codex",
    "EXECUTION_SCENARIO": "success",
    "TRUSTED_EXECUTION_SCENARIO": "success",
    "INDEPENDENT_REVIEW_ENABLED": "true",
    "INDEPENDENT_REVIEW_SCENARIO": "success",
    "GITHUB_APP_ID": "4281837",
    "GITHUB_INSTALLATION_ID": "146147681",
    "GITHUB_REVIEW_CHECKS_ENABLED": "true",
    "ALLOWED_REPOSITORY_PATH": "/workspace/roundhouse",
    "ALLOWED_REMOTE_URL": "https://github.com/zorkian/roundhouse.git",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "roundhouse-dev-coordination",
      "database_id": "87a4098a-a829-4e0b-80c6-43e2eaf34ddc",
      "migrations_dir": "migrations",
    },
  ],
  "r2_buckets": [
    {
      "binding": "EXECUTION_EVIDENCE",
      "bucket_name": "roundhouse-dev-evidence",
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "EXECUTION_CONTAINERS",
        "class_name": "RoundhouseExecutionContainer",
      },
    ],
  },
  "migrations": [
    {
      "tag": "execution-container-v1",
      "new_sqlite_classes": ["RoundhouseExecutionContainer"],
    },
  ],
  "containers": [
    {
      "name": "roundhouse-dev-execution",
      "class_name": "RoundhouseExecutionContainer",
      "image": "../../containers/roundhouse-execution/Dockerfile",
      "image_build_context": "../..",
      "max_instances": 1,
      "instance_type": "standard-1",
      "rollout_step_percentage": 100,
      "rollout_active_grace_period": 0,
    },
  ],
  "queues": {
    "producers": [
      {
        "binding": "RUN_QUEUE",
        "queue": "roundhouse-dev-runs",
      },
    ],
    "consumers": [
      {
        "queue": "roundhouse-dev-runs",
        "dead_letter_queue": "roundhouse-dev-runs-dlq",
        "max_retries": 3,
        "max_batch_size": 1,
        "max_batch_timeout": 1,
      },
    ],
  },
}
